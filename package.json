{
  "name": "kis2026_base",
  "version": "1.0.0",
  "description": "Block theme base for KIS.",
  "type": "commonjs",
  "author": "Koutarou ISHIKAWA",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stein2nd/kis2026_base.git"
  },
  "homepage": "https://github.com/stein2nd/kis2026_base#readme",
  "bugs": {
    "url": "https://github.com/stein2nd/kis2026_base/issues"
  },
  "keywords": [
    "wordpress",
    "blocktheme"
  ],
  "directories": {
    "doc": "docs"
  },
  "main": "build/index.js",
  "scripts": {
    "build": "FLUSH_DIST=true vite build --mode production",
    "build:dev": "FLUSH_DIST=true vite build --mode development",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "eslint src/scripts/**/*.ts",
    "lint:css": "stylelint src/styles/**/*.scss",
    "lint:fix": "npm run lint:js:fix && npm run lint:css:fix",
    "lint:js:fix": "eslint src/scripts/**/*.ts --fix",
    "lint:css:fix": "stylelint src/styles/**/*.scss --fix",
    "format": "prettier --write \"src/**/*.{ts,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,scss}\""
  },
  "overrides": {
    "rollup": "^4.60.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jquery": "^4.0.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "rollup": "^4.60.0",
    "sass": "^1.98.0",
    "stylelint": "^17.5.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.2",
    "vite-plugin-static-copy": "^4.0.0"
  }
}
