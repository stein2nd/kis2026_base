{
  "name": "kis2026_base",
  "version": "1.0.0",
  "description": "Block theme base for KIS.",
  "type": "commonjs",
  "author": "Koutarou ISHIKAWA",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stein2nd/kis2026_base.git"
  },
  "homepage": "https://github.com/stein2nd/kis2026_base#readme",
  "bugs": {
    "url": "https://github.com/stein2nd/kis2026_base/issues"
  },
  "keywords": [
    "wordpress",
    "blocktheme"
  ],
  "directories": {
    "doc": "docs"
  },
  "main": "build/index.js",
  "scripts": {
    "lint": "npm run lint:js && npm run lint:css",
    "lint:ts": "eslint src/**/*.{ts,tsx} --ext .ts,.tsx",
    "lint:ts:fix": "eslint src/**/*.{ts,tsx} --ext .ts,.tsx --fix",
    "lint:scss": "stylelint src/**/*.scss",
    "lint:scss:fix": "stylelint src/**/*.scss --fix",
    "lint:docs": "s2j-docs-linter ./README.md ./docs/**/*.md ./docs_mod/**/*.md",
    "build:dev": "FLUSH_DIST=true vite build --mode development",
    "build": "FLUSH_DIST=true vite build --mode production",
    "dist:zip": "npm run build && node tools/dist/make-dist-zip.mjs",
    "dist:zip:ci": "node tools/dist/make-dist-zip.mjs",
    "format": "prettier --write \"src/**/*.{ts,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,scss}\""
  },
  "overrides": {
    "rollup": "^4.61.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@s2j/docs-linter": "^1.0.15",
    "@types/jquery": "^4.0.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "autoprefixer": "^10.5.0",
    "archiver": "^8.0.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "rollup": "^4.61.0",
    "sass": "^1.100.0",
    "stylelint": "^17.12.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-static-copy": "^4.1.0"
  }
}
